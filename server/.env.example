# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API Base URL (optional, default: https://api.deepseek.com/v1)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek Model (optional, default: deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat

# Server Port
PORT=3000

# JWT Secret (change in production!)
JWT_SECRET=change-me-to-a-random-string-in-production

# Daily quota per user
DAILY_QUOTA=10

# Database path
DB_PATH=./data/quota.db

# CORS origin (your frontend domain)
CORS_ORIGIN=*