# DeepSeek API Key (required for AI features)
DEEPSEEK_API_KEY=your-api-key-here

# DeepSeek API Base URL (optional)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek Model (optional)
DEEPSEEK_MODEL=deepseek-chat

# Server Port
PORT=3000

# JWT Secret (REQUIRED - generate a secure random string)
JWT_SECRET=your-secure-random-jwt-secret-here

# JWT Configuration (optional)
JWT_ISSUER=ai-tool-hub
JWT_AUDIENCE=ai-tool-hub-users

# Daily quota per user (free tier)
DAILY_QUOTA=1

# Database path
DB_PATH=./data/quota.db

# CORS origin (comma-separated list, no wildcard in production)
CORS_ORIGIN=https://weihub.cloud,http://localhost:3000

# Environment (development/production)
NODE_ENV=development

# ===== 支付宝配置 =====
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://weihub.cloud/api/v1/payment/notify/alipay

# ===== 微信支付配置 =====
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://weihub.cloud/api/v1/payment/notify/wechat
WECHAT_CERT_PATH=