# AI Tool Hub 环境变量配置
# 复制此文件为 .env 并填入实际值

# GitHub OAuth 配置
# 在 https://github.com/settings/developers 创建 OAuth App 获取
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# GitHub API 配置（用于 Gist 同步）
# 需要有 gist 权限的 personal access token
VITE_GITHUB_TOKEN=your_github_token_here

# 应用配置
VITE_APP_NAME=AI Tool Hub
VITE_APP_VERSION=3.0.0

# 存储配置
VITE_STORAGE_KEY=ai-tool-hub-v3
VITE_GIST_FILENAME=ai-tool-hub-data.json

# 安全配置
# CSP 报告URI（可选，用于收集CSP违规报告）
VITE_CSP_REPORT_URI=

# 调试模式（开发环境设为 true）
VITE_DEBUG=false

# ── 服务器端配置 ──
JWT_SECRET=your_jwt_secret_here_min_32_chars
PASSWORD_PEPPER=your_password_pepper_here_min_32_chars
DEEPSEEK_API_KEY=your_deepseek_api_key_here
CORS_ORIGIN=https://weihub.cloud,http://localhost:3000
NODE_ENV=development
DAILY_QUOTA=1

# ── 支付配置（可选） ──
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=
